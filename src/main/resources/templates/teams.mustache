<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/style.css">
    <meta charset="UTF-8">
    <title>Teams</title>
</head>
<body>

<h1>F1 Teams</h1>

<table>
    <thead>
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Nationality</th>
        <th>Principal</th>
        <th>Championships Won</th>
        <th>Drivers</th>
    </tr>
    </thead>
    <tbody>
    {{#teams}}
    <tr>
        <td>{{id}}</td>
        <td>{{name}}</td>
        <td>{{nationality}}</td>
        <td>{{principal}}</td>
        <td>{{championshipsWon}}</td>
        <td>
            {{#drivers}}{{firstName}} {{lastName}}<br>{{/drivers}}
        </td>
    </tr>
    {{/teams}}
    </tbody>
</table>

<br>
<a href="/">Back to Home</a>

</body>
</html>