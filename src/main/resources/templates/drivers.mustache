<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/style.css">
    <meta charset="UTF-8">
    <title>Drivers</title>
</head>
<body>

<h1>F1 Drivers</h1>

<table>
    <thead>
    <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Team</th>
    </tr>
    </thead>
    <tbody>
    {{#drivers}}
        <tr>
            <td>{{firstName}}</td>
            <td>{{lastName}}</td>
            <td>{{team.name}}</td>
        </tr>
    {{/drivers}}
    </tbody>
</table>

<br>
<a href="/">Back to Home</a>

</body>
</html>
